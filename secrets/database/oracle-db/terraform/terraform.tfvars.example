aws_region     = "us-east-1"
aws_profile    = null
name_prefix    = "vault-oracle-lab"
key_name       = "<ec2_key_pair_name>"
admin_ssh_cidr = "<your_admin_ip_cidr>"

# Leave null to use the latest Amazon Linux 2023 x86_64 AMI.
ami_id = null

instance_type    = "t3.medium"
root_volume_size = 30

vault_version   = "1.20.2+ent"
vault_log_level = "info"

# Set the Vault Enterprise license via an environment variable instead of
# committing it here:
#   export TF_VAR_vault_license="$VAULT_LICENSE"
vault_license = "<vault_license_text>"

oracle_instant_client_version  = "19_28"
oracle_instant_client_base_url = "https://download.oracle.com/otn_software/linux/instantclient/1928000"
oracle_plugin_version          = "v0.14.1+ent"

# Set these after the first apply creates the EC2 nodes and you initialize Vault:
#   export TF_VAR_vault_addr="http://<vault_node_public_ip>:8200"
#   export TF_VAR_vault_token="<token>"
#   export TF_VAR_register_oracle_plugin=true
# Keep vault_addr, vault_token, and register_oracle_plugin out of this file if
# you want to control them with TF_VAR_* environment variables.

extra_tags = {
  Owner = "<email_or_name>"
}
