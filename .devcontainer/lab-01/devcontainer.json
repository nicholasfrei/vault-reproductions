{
  "name": "vault-reproductions-lab-01",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "../.."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.hcl"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "VAULT_ADDR": "http://transit-vault:8200",
    "VAULT_TOKEN": "root"
  },
  "containerEnv": {
    "SKIP_SETCAP": "true"
  },
  "postStartCommand": "bash .devcontainer/lab-01/setup-loopback-hosts.sh && bash .devcontainer/run/start-vault.sh",
  "forwardPorts": [
    8200
  ]
}
