{
  "name": "vault-reproductions-lab-01",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "../.."
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "vault-professional-cert/lab-01-transit-auto-unseal-and-node-join.md"
      ]
    },
    "vscode": {
      "extensions": [
        "hashicorp.hcl"
      ],
      "settings": {
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "zenMode.restore": true,
        "zenMode.fullScreen": false,
        "zenMode.centerLayout": false,
        "terminal.integrated.profiles.linux": {
          "Lab 01: transit-vault": {
            "path": "/bin/bash",
            "args": [
              "--rcfile",
              "${containerWorkspaceFolder}/.devcontainer/lab-01/bashrc-transit-vault",
              "-i"
            ]
          },
          "Lab 01: vault-node-1": {
            "path": "/bin/bash",
            "args": [
              "--rcfile",
              "${containerWorkspaceFolder}/.devcontainer/lab-01/bashrc-vault-node-1",
              "-i"
            ]
          },
          "Lab 01: vault-node-2": {
            "path": "/bin/bash",
            "args": [
              "--rcfile",
              "${containerWorkspaceFolder}/.devcontainer/lab-01/bashrc-vault-node-2",
              "-i"
            ]
          }
        }
      }
    }
  },
  "remoteEnv": {
    "VAULT_ADDR": "http://transit-vault:8200",
    "VAULT_TOKEN": "root"
  },
  "containerEnv": {
    "SKIP_SETCAP": "true"
  },
  "postAttachCommand": "code --command workbench.action.toggleZenMode",
  "postStartCommand": "bash .devcontainer/lab-01/post-start.sh",
  "forwardPorts": [
    8200
  ]
}
