aws_region     = "us-east-1"
aws_profile    = null
name_prefix    = "vault-lab"
key_name       = "<ec2_key_pair_name>"
admin_ssh_cidr = "<your_admin_ip_cidr>"

# Leave null to use the latest hc-base-al2023 x86_64 AMI.
ami_id = null

# Keep x86_64 by default because the Vault setup scripts currently assume amd64 artifacts.
ami_architecture = "x86_64"

instance_type    = "m6i.large"
root_volume_size = 40

vault_version   = "2.0.0"
vault_log_level = "trace"

# Set the Vault Enterprise license via an environment variable instead of
# committing it here:
#   export TF_VAR_vault_license="$VAULT_LICENSE"
vault_license = "<vault_license_text>"

extra_tags = {
  Owner = "<email_or_name>"
}
